{
    "version": 2,
    "builds": [
        {
            "src": "client/package.json",
            "use": "@vercel/next"
        }
    ],
    "routes": [
        {
            "src": "/(sitemap.xml|robots.txt)",
            "dest": "/client/$1",
            "continue": true
        },
        {
            "src": "/(.*)",
            "dest": "/client/$1"
        }
    ]
}